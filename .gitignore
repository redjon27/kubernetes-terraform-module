# Terraform working directory
**/.terraform/*
.terraform/

# Terraform state
*.tfstate
*.tfstate.*

# Plans
*.tfplan
*.tfplan.*

# Crash logs
crash.log
crash.*.log

# Override files (local-only)
# override.tf
# override.tf.json
# *_override.tf
# *_override.tf.json

# CLI config (local)
.terraformrc
terraform.rc

# Terragrunt
.terragrunt-cache/

# macOS / IDE
.DS_Store
.idea/
.vscode/
# Ignore real tfvars (can contain sensitive data)
# *.tfvars
# *.tfvars.json

# Allow examples
# !terraform.tfvars.example
